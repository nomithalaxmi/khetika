# ─── LLM (required for chat — fixes "Sorry, something went wrong") ─────────
# Get a free key: https://console.groq.com -> API Keys -> Create API Key
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# Fallback if GROQ_API_KEY is empty (requires Ollama running locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_VISION_MODEL=llava

# ─── Mandi Prices (fixes always-showing "Sample" badge) ─────────────────────
# Get a free key: https://data.gov.in -> Login -> My Account -> API Keys
DATA_GOV_API_KEY=

# ─── Optional features ───────────────────────────────────────────────────
OPENWEATHER_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
CRON_SECRET=

# ─── Flask ────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-string
